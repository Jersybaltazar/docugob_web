# DocuGob — supply-chain hardening (pnpm 11+).
#
# Reject packages published less than 24h ago. Buys us a window for
# the community to discover compromised releases before our CI/dev
# machines fetch them. Combined with the `onlyBuiltDependencies`
# allow-list in package.json this is our two-layer defense against
# the kind of npm worms seen in 2025-2026 (Shai-Hulud, qix, etc.).
minimum-release-age=1440

# Pnpm refuses ANY post-install lifecycle script except for packages
# explicitly listed under `pnpm.onlyBuiltDependencies` in package.json.
# Keep that list as small as possible.
# (`auto-install-peers` is left at its default `true` for ergonomics.)
